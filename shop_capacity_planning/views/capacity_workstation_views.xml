<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_capacity_workstation_form" model="ir.ui.view">
        <field name="name">capacity.workstation.form</field>
        <field name="model">capacity.workstation</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button name="action_view_work_orders" type="object"
                                class="oe_stat_button" icon="fa-tasks">
                            <field name="work_order_count" widget="statinfo" string="Work Orders"/>
                        </button>
                    </div>
                    <div class="oe_title">
                        <label for="name"/>
                        <h1><field name="name"/></h1>
                    </div>
                    <group>
                        <group string="Identification">
                            <field name="code"/>
                            <field name="sequence"/>
                            <field name="active" widget="boolean_toggle"/>
                            <field name="color" widget="color_picker"/>
                        </group>
                        <group string="Capacity Settings">
                            <field name="machine_count"/>
                            <field name="operator_count"/>
                            <field name="available_hours_day"/>
                            <field name="working_days_week"/>
                            <field name="weekly_available_hours" readonly="1"/>
                            <field name="efficiency_target"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Notes">
                            <field name="notes" placeholder="Workstation notes, constraints, or special requirements..."/>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_capacity_workstation_list" model="ir.ui.view">
        <field name="name">capacity.workstation.list</field>
        <field name="model">capacity.workstation</field>
        <field name="arch" type="xml">
            <list>
                <field name="sequence" widget="handle"/>
                <field name="name"/>
                <field name="code"/>
                <field name="machine_count"/>
                <field name="operator_count"/>
                <field name="available_hours_day"/>
                <field name="working_days_week"/>
                <field name="weekly_available_hours"/>
                <field name="efficiency_target" string="Target %"/>
                <field name="work_order_count" string="Active Orders"/>
                <field name="active" column_invisible="True"/>
            </list>
        </field>
    </record>

    <record id="view_capacity_workstation_kanban" model="ir.ui.view">
        <field name="name">capacity.workstation.kanban</field>
        <field name="model">capacity.workstation</field>
        <field name="arch" type="xml">
            <kanban>
                <field name="name"/>
                <field name="code"/>
                <field name="color"/>
                <field name="machine_count"/>
                <field name="operator_count"/>
                <field name="weekly_available_hours"/>
                <field name="efficiency_target"/>
                <field name="work_order_count"/>
                <templates>
                    <t t-name="card">
                        <div t-attf-class="oe_kanban_color_#{record.color.raw_value}">
                            <div class="oe_kanban_details">
                                <strong class="o_kanban_record_title">
                                    <field name="name"/>
                                    <span class="text-muted ms-1">(<field name="code"/>)</span>
                                </strong>
                                <div class="o_kanban_record_subtitle mt-2">
                                    <i class="fa fa-industry me-1"/>
                                    <t t-esc="record.machine_count.raw_value"/> machines /
                                    <t t-esc="record.operator_count.raw_value"/> operators
                                </div>
                                <div class="mt-1">
                                    <i class="fa fa-clock-o me-1"/>
                                    <strong><t t-esc="record.weekly_available_hours.raw_value"/> hrs/week</strong>
                                </div>
                                <div class="mt-1">
                                    <span class="badge bg-info">
                                        Target: <t t-esc="record.efficiency_target.raw_value"/>%
                                    </span>
                                    <span class="badge bg-primary ms-1">
                                        <t t-esc="record.work_order_count.raw_value"/> orders
                                    </span>
                                </div>
                            </div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <record id="action_capacity_workstation" model="ir.actions.act_window">
        <field name="name">Workstations</field>
        <field name="res_model">capacity.workstation</field>
        <field name="view_mode">kanban,list,form</field>
        <field name="context">{'search_default_active': 1}</field>
    </record>
</odoo>
